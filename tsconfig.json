{
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": ".",
        "outDir": "dist",
        "jsx": "react-jsx",
        "module": "esnext",
        "target": "esnext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "moduleResolution": "bundler",
        "allowJs": true,
        "noEmit": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "noUnusedLocals": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "isolatedModules": true,
        "inlineSources": true,
        "sourceMap": true,
        "sourceRoot": "/",
        "downlevelIteration": true,
        "noImplicitReturns": true,
        "strict": true,
        "paths": {
            "*": ["typings/*"]
        }
    },
    "include": [
        "DbViewerApiFake.ts",
        "index.tsx",
        "src/**/*",
        "stories/**/*",
        "tests/**/*",
        "typings/**/*"
    ],
    "exclude": ["**/node_modules/**/*", "**/.*/"]
}
